{
  "display_information": {
    "name": "Smart Connector Bot",
    "description": "AI co-pilot that identifies and connects you with the right people to solve your problem",
    "background_color": "#1a1a2e"
  },
  "features": {
    "bot_user": {
      "display_name": "Smart Connector Bot",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "chat:write.public"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "",
      "bot_events": [
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false
  }
}
